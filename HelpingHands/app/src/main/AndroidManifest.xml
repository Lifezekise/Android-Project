<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.athisintiya.helpinghands">

    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <application
        android:name=".HelpingHandsApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HelpingHands">

        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="helping_hands_channel" />
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="@string/google_maps_key" />
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <activity
            android:name=".dashboard.WelcomeActivity"
            android:exported="true"
            android:theme="@style/Theme.HelpingHands">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.HelpingHands" />
        <activity
            android:name=".auth.SignupActivity"
            android:exported="false"
            android:theme="@style/Theme.HelpingHands" />
        <activity
            android:name=".dashboard.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.HelpingHands" />
        <activity
            android:name=".dashboard.ResourcesActivity"
            android:exported="false"
            android:theme="@style/Theme.HelpingHands" />
        <activity
            android:name=".dashboard.ReportActivity"
            android:exported="false"
            android:theme="@style/Theme.HelpingHands" />
        <activity
            android:name=".dashboard.AccountActivity"
            android:exported="false"
            android:theme="@style/Theme.HelpingHands" />
        <activity
            android:name=".dashboard.DonateActivity"
            android:exported="false"
            android:theme="@style/Theme.HelpingHands" />
        <activity
            android:name=".dashboard.FoodDonationActivity"
            android:exported="false"
            android:theme="@style/Theme.HelpingHands" />
        <activity
            android:name=".dashboard.GoodsDonationActivity"
            android:exported="false"
            android:theme="@style/Theme.HelpingHands" />
        <activity
            android:name=".dashboard.VolunteerActivity"
            android:exported="false"
            android:theme="@style/Theme.HelpingHands" />
        <activity android:name=".dashboard.MoneyDonationActivity" />
    </application>
</manifest>