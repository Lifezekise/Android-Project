<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.HelpingHands" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>
        <item name="colorOnPrimaryContainer">@color/primary_dark</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/secondary_light</item>
        <item name="colorOnSecondaryContainer">@color/secondary_dark</item>

        <!-- Status bar -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimary</item>

        <!-- Surface colors -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/background</item>

        <!-- Error color -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>

        <!-- Shape appearance -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Large</item>

        <!-- Custom component styles -->
        <item name="materialButtonStyle">@style/FilledButtonStyle</item>
        <item name="materialCardViewStyle">@style/CardStyle</item>
    </style>

    <style name="Theme.HelpingHands" parent="Base.Theme.HelpingHands" />

    <style name="Theme.HelpingHands.DayNight" parent="Base.Theme.HelpingHands" />
</resources>