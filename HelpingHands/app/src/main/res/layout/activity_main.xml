<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            android:theme="@style/ThemeOverlay.Material3.Dark"
            app:title="Helping Hands"
            app:navigationIcon="@drawable/ic_menu" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FCFAF9"
            android:padding="16dp"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- Welcome Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/primary_light"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:background="@drawable/gradient_primary">

                        <TextView
                            android:id="@+id/app_name_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Helping Hands"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/tvWelcomeMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Community support and resources"
                            android:textSize="13sp"
                            android:textColor="#E2E8F0"
                            android:layout_marginTop="6dp"
                            android:gravity="center" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Quick Actions -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="3"
                    android:alignmentMode="alignMargins"
                    android:columnOrderPreserved="false"
                    android:rowOrderPreserved="false"
                    android:padding="4dp">

                    <!-- Find Help -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/find_help_button"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        android:layout_rowWeight="1"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp"
                        app:strokeColor="#DCFCE7"
                        app:strokeWidth="1dp"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_resources"
                                app:tint="@color/success_green" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Find Help"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@android:color/black"
                                android:gravity="center"
                                android:layout_marginTop="6dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Donate -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/donate_button"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        android:layout_rowWeight="1"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp"
                        app:strokeColor="#DBEAFE"
                        app:strokeWidth="1dp"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_donate"
                                app:tint="@color/primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Donate"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@android:color/black"
                                android:gravity="center"
                                android:layout_marginTop="6dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Volunteer -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/volunteer_button"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        android:layout_rowWeight="1"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp"
                        app:strokeColor="#F3E8FF"
                        app:strokeWidth="1dp"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_volunteer"
                                app:tint="@color/purple_500" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Volunteer"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@android:color/black"
                                android:gravity="center"
                                android:layout_marginTop="6dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- My Account -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/account_button"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        android:layout_rowWeight="1"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp"
                        app:strokeColor="#FFF7ED"
                        app:strokeWidth="1dp"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_account"
                                app:tint="@color/orange_500" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="My Account"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@android:color/black"
                                android:gravity="center"
                                android:layout_marginTop="6dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Report Issue -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardReport"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        android:layout_rowWeight="1"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="1dp"
                        app:strokeColor="#FECACA"
                        app:strokeWidth="1dp"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_report"
                                app:tint="@color/red_500" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Report Issue"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@android:color/black"
                                android:gravity="center"
                                android:layout_marginTop="6dp" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </GridLayout>

                <!-- Resources Section -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    android:backgroundTint="#F0F9FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/resources_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Resources"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/black"
                            android:layout_marginBottom="10dp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="[List of nearby resources will go here]"
                            android:gravity="center"
                            android:padding="14dp"
                            android:background="#f0f0f0"
                            android:textColor="@android:color/darker_gray"
                            android:textSize="13sp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/surface"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu" />

</androidx.drawerlayout.widget.DrawerLayout>