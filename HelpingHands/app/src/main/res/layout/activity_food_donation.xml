<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FCFAF9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#FCFAF9"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/food_donation_form"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/food_type"
            android:textSize="16sp"
            android:textColor="#374151"/>
        <Spinner
            android:id="@+id/spFoodType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/rounded_text_bg"
            android:entries="@array/food_types"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quantity"
            android:textSize="16sp"
            android:textColor="#374151"
            android:layout_marginTop="16dp"/>
        <EditText
            android:id="@+id/etQuantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/quantity"
            android:inputType="number"
            android:textSize="18sp"
            android:textColor="#1F2937"
            android:padding="12dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rounded_text_bg"/>

        <CheckBox
            android:id="@+id/cbPerishable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/perishable"
            android:textSize="16sp"
            android:textColor="#374151"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/special_instructions"
            android:textSize="16sp"
            android:textColor="#374151"
            android:layout_marginTop="16dp"/>
        <EditText
            android:id="@+id/etSpecialInstructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/special_instructions"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:textSize="18sp"
            android:textColor="#1F2937"
            android:padding="12dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rounded_text_bg"/>

        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/submit_donation_button"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:backgroundTint="#2563EB"
            android:textColor="@android:color/white"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"/>
        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back_to_dashboard_button"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:backgroundTint="#2563EB"
            android:textColor="@android:color/white"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"/>

    </LinearLayout>
</ScrollView>