<?xml version="1.0" encoding="utf-8"?>
<!--
  This XML layout defines the "My Account" screen for the "Helping Hands" app.
  It is styled to match the visual design provided in the document.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FCFAF9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#FCFAF9"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Account"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Name"
            android:textSize="16sp"
            android:textColor="#374151"/>
        <TextView
            android:id="@+id/tvFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="#1F2937"
            android:padding="12dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rounded_text_bg"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Username"
            android:textSize="16sp"
            android:textColor="#374151"
            android:layout_marginTop="16dp"/>
        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="#1F2937"
            android:padding="12dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rounded_text_bg"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/donation_count"
            android:textSize="16sp"
            android:textColor="#374151"
            android:layout_marginTop="16dp"/>
        <TextView
            android:id="@+id/tvDonationCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Donations: "
            android:textSize="18sp"
            android:textColor="#1F2937"
            android:padding="12dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/rounded_text_bg"/>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back to Dashboard"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:backgroundTint="#2563EB"
            android:textColor="@android:color/white"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/logout"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:backgroundTint="#2563EB"
            android:textColor="@android:color/white"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"/>

    </LinearLayout>
</ScrollView>