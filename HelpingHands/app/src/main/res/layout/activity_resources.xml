<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <!-- Header Layout -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Helping Hands"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find shelters, healthcare, and food resources near you"
            android:textSize="16sp"
            android:textColor="@color/on_surface_variant"
            android:layout_marginBottom="16dp"/>
    </LinearLayout>

    <!-- Search Layout -->
    <LinearLayout
        android:id="@+id/searchLayout"
        android:layout_below="@id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/rounded_edittext_bg"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search for shelters, food, healthcare..."
            android:textColor="@color/on_surface"
            android:textColorHint="@color/on_surface_variant"
            android:background="@null"
            android:padding="12dp"
            android:imeOptions="actionSearch"
            android:inputType="text"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSearch"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Search"
            app:icon="@drawable/ic_search"
            app:iconTint="@color/primary"
            style="@style/Widget.Material3.IconButton"
            app:backgroundTint="@android:color/transparent"/>
    </LinearLayout>

    <!-- Filter Chips (REPLACED BUTTONS) -->
    <HorizontalScrollView
        android:id="@+id/filterScrollView"
        android:layout_below="@id/searchLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipShelters"
                style="@style/FilterChipStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shelters"
                android:checkable="true"
                app:chipIcon="@drawable/ic_shelter"
                app:chipIconTint="@color/on_surface_variant" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipHealthcare"
                style="@style/FilterChipStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Healthcare"
                android:checkable="true"
                app:chipIcon="@drawable/ic_healthcare"
                app:chipIconTint="@color/on_surface_variant" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFood"
                style="@style/FilterChipStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Food"
                android:checkable="true"
                app:chipIcon="@drawable/ic_food"
                app:chipIconTint="@color/on_surface_variant" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                style="@style/FilterChipStyleSelected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All Resources"
                android:checked="true"
                android:checkable="true"
                app:chipIcon="@drawable/ic_all"
                app:chipIconTint="@color/white" />

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- Nearest Resource Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardNearestResource"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/CardStyle"
        android:layout_below="@id/filterScrollView"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivResourceIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="8dp"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📍 Nearest Resource"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:id="@+id/tvResourceStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟢 Open"
                    android:textSize="12sp"
                    android:textColor="@color/success"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvResourceName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cape Town Central Shelter"
                android:textSize="14sp"
                android:textColor="@color/on_surface"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvResourceAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="123 Long Street, Cape Town"
                android:textSize="12sp"
                android:textColor="@color/on_surface_variant"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvResourceDistance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="1.2 km away"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvResourceHours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open until 10 PM"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGetDirections"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Get Directions"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_marginTop="12dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Map Container -->
    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_below="@id/cardNearestResource"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_above="@+id/buttonLayout"
        android:layout_marginBottom="16dp"
        android:background="@drawable/map_border">

        <fragment
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:context=".dashboard.ResourcesActivity"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabCurrentLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_margin="16dp"
            android:contentDescription="Current location"
            app:srcCompat="@drawable/ic_my_location"
            app:backgroundTint="@color/primary"
            app:tint="@color/white" />

    </FrameLayout>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:weightSum="2"
        android:padding="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Back to Dashboard"
            android:textColor="@color/white"
            app:backgroundTint="@color/primary"
            android:layout_marginEnd="4dp"
            style="@style/Widget.Material3.Button"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDirections"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Get Directions"
            android:textColor="@color/white"
            app:backgroundTint="@color/secondary"
            android:layout_marginStart="4dp"
            app:icon="@drawable/ic_directions"
            app:iconTint="@color/white"
            style="@style/Widget.Material3.Button"/>
    </LinearLayout>

</RelativeLayout>